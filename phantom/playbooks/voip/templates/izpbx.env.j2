# izPBX Environment Configuration — generated by Phantom
# Do not edit manually; re-deploy to update.

APP_FQDN={{ izpbx_hostname }}
APP_PORT_HTTP=80
APP_PORT_HTTPS=443
TZ={{ izpbx_timezone }}

# Database
MYSQL_SERVER=127.0.0.1
MYSQL_DATABASE=asterisk
MYSQL_USER=asterisk
MYSQL_PASSWORD={{ izpbx_db_password }}
MYSQL_ROOT_PASSWORD={{ izpbx_db_root_password }}

# HTTPS
HTTPD_HTTPS_ENABLED=true
HTTPD_REDIRECT_HTTP_TO_HTTPS=true

# Let's Encrypt
LETSENCRYPT_ENABLED={{ 'false' if izpbx_hostname | regex_search('^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+$') else 'true' }}
LETSENCRYPT_COUNTRY_CODE=US

# Fail2Ban
FAIL2BAN_ENABLED=true
FAIL2BAN_ASTERISK_ENABLED=true
FAIL2BAN_ASTERISK_MAXRETRY=5

# FreePBX
FREEPBX_AUTOUPGRADE_CORE=true
FREEPBX_AUTOUPGRADE_MODULES=true

# SIP/RTP ports
APP_PORT_SIP=5060
APP_PORT_PJSIP=5160
APP_PORT_IAX=4569
APP_PORT_WEBRTC=8089
APP_PORT_RTP_START=10000
APP_PORT_RTP_END=20000
