# Mailcow configuration — generated by Phantom
# Do not run generate_config.sh; this file replaces it.

# Hostname and timezone
MAILCOW_HOSTNAME={{ mailcow_hostname }}
MAILCOW_TZ={{ mailcow_timezone }}
TZ={{ mailcow_timezone }}

# Database
DBNAME=mailcow
DBUSER=mailcow
DBPASS={{ mailcow_db_password }}
DBROOT={{ mailcow_db_root_password }}

# HTTP/S bindings
HTTP_PORT=80
HTTPS_PORT=443
HTTP_BIND={{ mailcow_http_bind | default('0.0.0.0') }}
HTTPS_BIND={{ mailcow_https_bind | default('0.0.0.0') }}

# API access
API_KEY={{ mailcow_api_key }}
API_KEY_READ_ONLY=
API_ALLOW_FROM={{ mailcow_api_allow_from | default('127.0.0.1,172.22.1.0/24') }}

# TLS
SKIP_LETS_ENCRYPT={{ mailcow_skip_le | default('n') }}
SKIP_SOGO={{ mailcow_skip_sogo | default('n') }}
SKIP_SOLR={{ mailcow_skip_solr | default('y') }}
SKIP_CLAMD={{ mailcow_skip_clamd | default('n') }}

# Logging
LOG_LINES=9999
COMPOSE_PROJECT_NAME=mailcowdockerized

# Branch
MAILCOW_GIT_URL=https://github.com/mailcow/mailcow-dockerized
MAILCOW_GIT_BRANCH=master

# ACL
ACL_ANYONE=disallow

# Rspamd
RSPAMD_UI_PASS=

# SOGo Workers
SOGO_EXPIRE_SESSION=480

# Watchdog
WATCHDOG_NOTIFY_EMAIL=
WATCHDOG_NOTIFY_BAN=y
WATCHDOG_NOTIFY_START=n
WATCHDOG_EXTERNAL_CHECKS=n
WATCHDOG_MYSQL_REPLICATION_CHECKS=n
WATCHDOG_VERBOSE=n
USE_WATCHDOG=y

# IPv4/IPv6
SNAT_TO_SOURCE=
SNAT6_TO_SOURCE=
IPV4_NETWORK=172.22.1
IPV6_NETWORK=fd4d:6169:6c63:6f77::/64

# Compose
DOCKER_COMPOSE_VERSION=native
ADDITIONAL_SAN=
ADDITIONAL_SERVER_NAMES=

# Mail settings
MAILDIR_GC_TIME=7200
MAILDIR_SUB=Maildir
MAILCOW_PASS_SCHEME=BLF-CRYPT

# Solr/FTS (disabled by default)
SOLR_HEAP=1024
SKIP_FTS=y
FTS_HEAP=256
FTS_PROCS=1

# Dovecot settings
DOVECOT_MASTER_USER=
DOVECOT_MASTER_PASS=
FLATCURVE_EXPERIMENTAL=n
ALLOW_ADMIN_EMAIL_LOGIN=n

# Redis
REDIS_PORT=127.0.0.1:7654
REDISPASS={{ mailcow_redis_password }}

# Unbound
UNBOUND_PORT=127.0.0.1:13053

# Ports (mail services)
SMTP_PORT=25
SMTPS_PORT=465
SUBMISSION_PORT=587
IMAP_PORT=143
IMAPS_PORT=993
POP_PORT=110
POPS_PORT=995
SIEVE_PORT=4190
DOVEADM_PORT=127.0.0.1:19991
SQL_PORT=127.0.0.1:13306

# Master node
MASTER=y

# Netfilter
DISABLE_NETFILTER_ISOLATION_RULE=n

# SSL SNI
ENABLE_SSL_SNI=n

# HTTP redirect
HTTP_REDIRECT=n

# IP check / verification
SKIP_IP_CHECK=n
SKIP_HTTP_VERIFICATION=y
SKIP_UNBOUND_HEALTHCHECK=y
SKIP_OLEFY=n

# Spamhaus
SPAMHAUS_DQS_KEY=

# WebAuthn
WEBAUTHN_ONLY_TRUSTED_VENDORS=n

# Autodiscover
AUTODISCOVER_SAN=

# SOGo URL encryption
SOGO_URL_ENCRYPTION_KEY=

# Misc
DOCKER_COMPOSE_EXTRA_FLAGS=
