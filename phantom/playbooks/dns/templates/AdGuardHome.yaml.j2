# AdGuard Home configuration
http:
  address: 0.0.0.0:3000
  session_ttl: 720h
users:
  - name: admin
    password: {{ adguard_bcrypt_hash }}
dns:
  bind_hosts:
    - 0.0.0.0
  port: 53
  upstream_dns:
{% for server in adguard_upstream %}
    - {{ server }}
{% endfor %}
  bootstrap_dns:
    - 9.9.9.9
    - 1.1.1.1
  protection_enabled: true
  filtering_enabled: true
  blocking_mode: default
  cache_size: 4194304
  cache_ttl_min: 0
  cache_ttl_max: 0
  enable_dnssec: true
  ratelimit: 0
tls:
{% if dns_domain is defined and dns_domain %}
  enabled: true
  server_name: {{ dns_domain }}
  force_https: false
  port_https: 0
  port_dns_over_tls: 853
  port_dns_over_quic: 0
  certificate_path: {{ _ssl_cert | default('') }}
  private_key_path: {{ _ssl_key | default('') }}
  strict_sni_check: false
  allow_unencrypted_doh: false
{% else %}
  enabled: false
{% endif %}
filters:
{% if adguard_blocklist == 'minimal' %}
  - enabled: true
    url: https://adguardteam.github.io/HostlistsRegistry/assets/filter_1.txt
    name: AdGuard DNS filter
    id: 1
{% elif adguard_blocklist == 'standard' %}
  - enabled: true
    url: https://adguardteam.github.io/HostlistsRegistry/assets/filter_1.txt
    name: AdGuard DNS filter
    id: 1
  - enabled: true
    url: https://adguardteam.github.io/HostlistsRegistry/assets/filter_59.txt
    name: AdGuard DNS Popup Hosts filter
    id: 59
  - enabled: true
    url: https://adguardteam.github.io/HostlistsRegistry/assets/filter_33.txt
    name: Steven Black unified hosts
    id: 33
{% elif adguard_blocklist == 'aggressive' %}
  - enabled: true
    url: https://adguardteam.github.io/HostlistsRegistry/assets/filter_1.txt
    name: AdGuard DNS filter
    id: 1
  - enabled: true
    url: https://adguardteam.github.io/HostlistsRegistry/assets/filter_59.txt
    name: AdGuard DNS Popup Hosts filter
    id: 59
  - enabled: true
    url: https://adguardteam.github.io/HostlistsRegistry/assets/filter_33.txt
    name: Steven Black unified hosts
    id: 33
  - enabled: true
    url: https://adguardteam.github.io/HostlistsRegistry/assets/filter_48.txt
    name: HaGeZi Pro DNS Blocklist
    id: 48
  - enabled: true
    url: https://adguardteam.github.io/HostlistsRegistry/assets/filter_44.txt
    name: HaGeZi Threat Intelligence Feeds
    id: 44
  - enabled: true
    url: https://adguardteam.github.io/HostlistsRegistry/assets/filter_11.txt
    name: Malicious URL Blocklist (URLHaus)
    id: 11
{% endif %}
schema_version: 28
