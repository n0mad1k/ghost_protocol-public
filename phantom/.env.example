# ============================================================
# Phantom — Environment Configuration
# ============================================================
# Copy to .env and fill in values for unattended deployments.
# All service-specific keys use the PHANTOM_ prefix.
# Bare variants (without prefix) are also accepted for most
# service keys — PHANTOM_ takes priority when both are set.
# ============================================================

# --- Provider & Infrastructure ---
PHANTOM_PROVIDER=existing
# Options: existing, linode, aws

PHANTOM_DOMAIN=
# FQDN for TLS certs and service URLs (e.g. example.com)

PHANTOM_DEPLOYMENT_ID=
# Reuse a previous deployment's ID to update in-place

# --- Target Server (for 'existing' provider) ---
PHANTOM_TARGET_HOST=
# IP or hostname of the target server

PHANTOM_SSH_USER=
# SSH login user (default: root)

PHANTOM_SSH_KEY=
# Path to SSH private key (e.g. ~/.ssh/id_ed25519)

PHANTOM_BECOME_PASSWORD=
# sudo password if the SSH user is not root

# --- Linode ---
LINODE_TOKEN=
LINODE_REGION=us-east
# LINODE_PLAN=
# Auto-selected per service; override here to force a specific plan

# --- AWS ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# AWS_INSTANCE_TYPE=
# Auto-selected per service; override here to force a specific type

# --- Cloudflare Tunnel ---
PHANTOM_CF_TUNNEL_TOKEN=
# Connector token from `cloudflared tunnel create`

# --- Matrix (chat) ---
PHANTOM_MATRIX_ADMIN_USER=
PHANTOM_MATRIX_ADMIN_PASSWORD=
PHANTOM_MATRIX_REGISTRATION=
# Allow public registration: true / false
PHANTOM_MATRIX_ELEMENT_WEB=
# Deploy Element Web client: true / false

# --- WireGuard VPN ---
PHANTOM_VPN_PORT=
# UDP listen port (default: 51820)
PHANTOM_VPN_CLIENT_COUNT=
# Number of client configs to generate (integer)
PHANTOM_VPN_DNS=
# DNS server for VPN clients (e.g. 10.66.0.1 for Pi-hole)
PHANTOM_VPN_ALLOWED_IPS=
# Client allowed IPs (e.g. 0.0.0.0/0 for full tunnel)
PHANTOM_VPN_SUBNET=
# WireGuard subnet (e.g. 10.66.0.0/24)

# --- Pi-hole DNS ---
PHANTOM_DNS_UPSTREAM=
# Upstream DNS servers (e.g. 1.1.1.1;9.9.9.9)
PHANTOM_DNS_BLOCKLIST=
# Custom blocklist URL
PHANTOM_DNS_DOMAIN=
# Local DNS domain
PHANTOM_DNS_ADMIN_USER=
PHANTOM_DNS_ADMIN_PASSWORD=

# --- Nextcloud (cloud) ---
PHANTOM_CLOUD_ADMIN_USER=
PHANTOM_CLOUD_ADMIN_PASSWORD=
PHANTOM_CLOUD_STORAGE_GB=
# Storage quota in GB (integer)

# --- Vaultwarden (vault) ---
PHANTOM_VAULT_ADMIN_TOKEN=
# Admin panel token
PHANTOM_VAULT_SIGNUPS_ALLOWED=
# Allow new user signups: true / false

# --- Jellyfin (media) ---
PHANTOM_MEDIA_LIBRARY_PATH=
# Path to media library on the server

# --- Email (Mailcow) ---
PHANTOM_EMAIL_HOSTNAME=
# Mail server FQDN — Mailcow binds to this (e.g. mx.example.com, post.example.com)
PHANTOM_EMAIL_DOMAIN=
# Base mail domain for MX/SPF/DKIM/DMARC records (e.g. example.com)
# Must differ from EMAIL_HOSTNAME
PHANTOM_EMAIL_TIMEZONE=
# Server timezone (e.g. America/New_York)
PHANTOM_EMAIL_FIRST_USER=
# Initial mailbox address (e.g. user@example.com)

# Outbound relay/smarthost (for smarthost mode — use RELAY_MODE=vps for VPS relay)
# PHANTOM_EMAIL_RELAY_HOST=      # e.g. smtp.sendgrid.net, smtp.mailgun.org
# PHANTOM_EMAIL_RELAY_PORT=587   # Usually 587 for STARTTLS
# PHANTOM_EMAIL_RELAY_USER=      # Relay auth username
# PHANTOM_EMAIL_RELAY_PASSWORD=  # Relay auth password

# Email relay VPS mode (for CGNAT/ISP port-25 blocking)
# PHANTOM_EMAIL_RELAY_MODE=         # none, vps, smarthost (default: none)
# PHANTOM_RELAY_PROVIDER=           # linode, aws (default: same as main)
# PHANTOM_RELAY_API_TOKEN=          # Separate API token for relay VPS (default: same)
# PHANTOM_RELAY_REGION=             # Region for relay VPS (default: same as main)

# --- Git (Gitea / Forgejo) ---
PHANTOM_GIT_PLATFORM=
# Options: gitea, forgejo
PHANTOM_GIT_SSH_PORT=
# SSH port for git operations (integer, e.g. 2222)
PHANTOM_GIT_ADMIN_USER=
PHANTOM_GIT_ADMIN_PASSWORD=
PHANTOM_GIT_ADMIN_EMAIL=

# --- VOIP (izPBX / FreePBX) ---
PHANTOM_VOIP_HOSTNAME=        # PBX FQDN (e.g. pbx.example.com)
PHANTOM_VOIP_ADMIN_PASSWORD=  # FreePBX admin password (auto-gen if blank)
PHANTOM_VOIP_PROVIDER=        # telnyx, voipms, twilio, generic, skip
PHANTOM_VOIP_SIP_HOST=        # SIP server hostname
PHANTOM_VOIP_SIP_PORT=        # SIP port (default 5060)
PHANTOM_VOIP_SIP_USERNAME=    # SIP auth username
PHANTOM_VOIP_SIP_PASSWORD=    # SIP auth password
PHANTOM_VOIP_SIP_TRANSPORT=   # udp, tcp, tls
PHANTOM_VOIP_TIMEZONE=        # e.g. America/New_York

# --- All-in-One Deployment ---
PHANTOM_SERVICES=
# Comma-separated list of services (e.g. matrix,vpn,dns)
PHANTOM_CERTBOT_EMAIL=
# Email for Let's Encrypt certificate notifications

# --- Maintenance Reports (SMTP) ---
PHANTOM_SMTP_HOST=            # SMTP server for maintenance reports (blank = skip)
PHANTOM_SMTP_PORT=587         # SMTP port
PHANTOM_SMTP_USER=            # SMTP username
PHANTOM_SMTP_PASSWORD=        # SMTP password
PHANTOM_SMTP_FROM=            # From address for reports
PHANTOM_REPORT_EMAIL=         # Recipient for maintenance reports
